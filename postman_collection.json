{
  "info": {
    "name": "Freelance Platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "job_gateway", "value": "http://localhost:8080" },
    { "key": "msg_gateway", "value": "http://localhost:8081" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Healthz",
          "request": {
            "method": "GET",
            "url": "{{job_gateway}}/healthz"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.user_id) pm.collectionVariables.set('user_id', json.user_id);",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{job_gateway}}/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"secret123\",\n  \"name\": \"Test User\",\n  \"role\": \"client\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);",
                  "if (json.user_id) pm.collectionVariables.set('user_id', json.user_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{job_gateway}}/users/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{job_gateway}}/users/{{user_id}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{job_gateway}}/users/{{user_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('job_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{job_gateway}}/jobs",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Go Developer\",\n  \"description\": \"Need experienced Go developer\",\n  \"budget\": 1000,\n  \"client_id\": \"{{user_id}}\"\n}"
            }
          }
        },
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{job_gateway}}/jobs?page=1&page_size=10",
              "host": ["{{job_gateway}}"],
              "path": ["jobs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Job",
          "request": {
            "method": "GET",
            "url": "{{job_gateway}}/jobs/{{job_id}}"
          }
        },
        {
          "name": "Apply to Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{job_gateway}}/jobs/{{job_id}}/apply",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"freelancer_id\": \"{{user_id}}\",\n  \"cover_letter\": \"I am interested in this job\"\n}"
            }
          }
        },
        {
          "name": "Accept Freelancer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{job_gateway}}/jobs/{{job_id}}/accept",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"freelancer_id\": \"{{user_id}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Messaging",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{user_id}}" }
            ],
            "url": "{{msg_gateway}}/api/messages",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiver_id\": \"receiver-user-id\",\n  \"content\": \"Hello from Postman!\"\n}"
            }
          }
        },
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-User-ID", "value": "{{user_id}}" }],
            "url": {
              "raw": "{{msg_gateway}}/api/messages?other_user_id=receiver-user-id",
              "host": ["{{msg_gateway}}"],
              "path": ["api", "messages"],
              "query": [{ "key": "other_user_id", "value": "receiver-user-id" }]
            }
          }
        },
        {
          "name": "Get Dialogs",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-User-ID", "value": "{{user_id}}" }],
            "url": "{{msg_gateway}}/api/dialogs"
          }
        }
      ]
    }
  ]
}
